<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<title>AWITA MEGA - Jasa AC & Teknik Gedung</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<style>
:root{
  --bg:#0f172a;
  --card:#1e293b;
  --text:#f1f5f9;
  --gold:#facc15;
}
*{box-sizing:border-box}
body{
  margin:0;
  font-family:Arial, sans-serif;
  background:var(--bg);
  color:var(--text);
  scroll-behavior:smooth;
}
header{
  position:sticky;top:0;z-index:10;
  background:#020617;
  display:flex;justify-content:space-between;align-items:center;
  padding:10px 15px;
}
header h1{margin:0;font-size:18px;color:var(--gold)}
nav a{
  color:white;text-decoration:none;margin-left:10px;font-size:14px;
}
.hero{
  text-align:center;padding:60px 20px;
  background:linear-gradient(135deg,#020617,#1e293b);
  animation:fade 1.5s ease;
}
.hero h2{color:var(--gold);font-size:28px}
.btn{
  display:inline-block;margin-top:20px;
  padding:12px 25px;border-radius:25px;
  background:var(--gold);color:black;
  text-decoration:none;font-weight:bold;
}
.section{padding:40px 20px}
.section h3{text-align:center;color:var(--gold)}
.card{
  background:var(--card);
  padding:15px;border-radius:12px;
  margin-bottom:15px;
  animation:up 1s ease;
}
ul{padding-left:20px}
footer{
  background:#020617;text-align:center;padding:15px;
  font-size:14px;color:#cbd5f5;
}
.toggle{
  position:fixed;bottom:15px;right:15px;
  background:var(--gold);color:black;
  border:none;border-radius:50%;
  width:45px;height:45px;font-size:18px;
}
@keyframes fade{from{opacity:0}to{opacity:1}}
@keyframes up{from{transform:translateY(20px);opacity:0}to{transform:translateY(0);opacity:1}}
</style>
</head>

<body>

<header>
  <h1>AWITA MEGA</h1>
  <nav>
    <a href="#home">Home</a>
    <a href="#about">Tentang</a>
    <a href="#service">Layanan</a>
    <a href="#contact">Kontak</a>
  </nav>
</header>

<section id="home" class="hero">
  <h2>Jasa AC & Teknik Gedung</h2>
  <p>Profesional • Berpengalaman • Bandung & Sekitarnya</p>
  <a class="btn" href="https://wa.me/628XXXXXXXXXX">📲 Hubungi via WhatsApp</a>
</section>

<section id="about" class="section">
  <h3>👷 Tentang Kami</h3>
  <div class="card">
    <p><b>AWITA MEGA</b> adalah penyedia jasa instalasi AC, maintenance, troubleshooting, electrical, dan support proyek gedung dengan tenaga ahli profesional.</p>
  </div>
</section>

<section id="service" class="section">
  <h3>🛠️ Layanan Kami</h3>
  <div class="card">
    <ul>
      <li>Instalasi AC Gedung</li>
      <li>Service & Maintenance AC</li>
      <li>Troubleshooting Sistem Pendingin</li>
      <li>Electrical & Panel Control</li>
      <li>BACnet Control</li>
      <li>Support Proyek Konstruksi Gedung</li>
    </ul>
  </div>
</section>

<section class="section">
  <h3>📍 Area Layanan</h3>
  <div class="card">
    Bandung, Cimahi, dan sekitarnya
  </div>
</section>

<section id="contact" class="section">
  <h3>📞 Kontak Kami</h3>
  <div class="card">
    <p>WhatsApp: <b>08XXXXXXXXXX</b></p>
    <p>Email: awitamega@email.com</p>
  </div>
  <a class="btn" href="https://wa.me/628XXXXXXXXXX">CHAT SEKARANG</a>
</section>

<footer>
  © 2026 AWITA MEGA | Jasa AC & Teknik Gedung
</footer>

<button class="toggle" onclick="mode()">🌓</button>

<script>
let dark=true;
function mode(){
  if(dark){
    document.documentElement.style.setProperty('--bg','#f1f5f9');
    document.documentElement.style.setProperty('--card','#ffffff');
    document.documentElement.style.setProperty('--text','#020617');
    dark=false;
  }else{
    document.documentElement.style.setProperty('--bg','#0f172a');
    document.documentElement.style.setProperty('--card','#1e293b');
    document.documentElement.style.setProperty('--text','#f1f5f9');
    dark=true;
  }
}
</script>

</body>
</html>
